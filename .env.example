# Copy this file to .env.local and fill in the values
# NEVER commit .env.local

# App
NEXT_PUBLIC_APP_URL=https://ameizze.com

# Database (SQLite)
DATABASE_URL="file:./prisma/prod.db"

# Stripe — get keys from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin credentials
ADMIN_EMAIL=admin@ameizze.com
ADMIN_PASSWORD_HASH=$2b$10$...   # bcrypt hash — generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"
ADMIN_JWT_SECRET=change-this-to-a-random-64-char-string

# Shippo — get key from goshippo.com
SHIPPO_API_KEY=shippo_live_...
